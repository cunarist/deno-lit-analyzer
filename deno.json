{
  "name": "@cunarist/deno-lit-analyzer",
  "version": "0.1.0",
  "nodeModulesDir": "auto",
  "exports": {
    ".": "./src/mod.ts"
  },
  "tasks": {
    "good": "cd tests/fixture && deno run -A ../../src/mod.ts good",
    "bad": "cd tests/fixture && deno run -A ../../src/mod.ts bad",
    "test": "deno test -A"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.ns", "deno.unstable", "es2022"]
  },
  "lint": {
    "exclude": ["tests/fixture"],
    "plugins": [
      "jsr:@hugoalh/deno-lint-rules@0.18.2/presets/cli",
      "jsr:@cunarist/deno-import-check@0.7.0/lint",
      "jsr:@cunarist/deno-lint-plugin-explicit-types@0.5.0/absence",
      "jsr:@cunarist/deno-lint-plugin-explicit-types@0.5.0/concrete",
      "jsr:@cunarist/deno-lint-plugin-explicit-types@0.5.0/naming"
    ],
    "rules": {
      "tags": ["recommended", "jsr"],
      "exclude": ["hugoalh/sort-depends"],
      "include": [
        "eqeqeq",
        "camelcase",
        "guard-for-in",
        "no-const-assign",
        "no-eval",
        "no-external-import",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-throw-literal",
        "prefer-ascii"
      ]
    }
  },
  "publish": {
    "exclude": ["tests"]
  },
  "imports": {
    "#options": "./src/options.ts",
    "#report": "./src/report.ts",
    "#analyze": "./src/analyze.ts",
    "#config": "./src/config.ts",
    "#files": "./src/files.ts",
    "lit-analyzer": "npm:lit-analyzer@2.0.3",
    "typescript": "npm:typescript@5.2.2",
    "lit": "npm:lit@^3.2.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/jsonc": "jsr:@std/jsonc@1",
    "@std/path": "jsr:@std/path@1"
  }
}
